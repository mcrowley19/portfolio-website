---
import { ClientRouter } from 'astro:transitions'
import Nav from '../components/Nav.astro'
import '../styles/global.css'
import frauncesNormalUrl from '@fontsource-variable/fraunces/files/fraunces-latin-wght-normal.woff2?url'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Michael Crowley — CS at Trinity College Dublin, CTO of Lockup',
  description = 'Computer Science student at Trinity College Dublin and CTO of Lockup, a phone-management app for schools. Builder of LLM tooling, full-stack web, and hardware prototypes.',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preload" as="font" type="font/woff2" href={frauncesNormalUrl} crossorigin />
    <slot name="head-preload" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Michael Crowley" />
    <link rel="canonical" href={`https://michaelcrowley.dev${Astro.url.pathname}`} />
    <link rel="alternate" type="text/markdown" href="/llms.txt" title="LLM-friendly site summary" />
    <link rel="alternate" type="text/markdown" href="/llms-full.txt" title="Full bio, projects, and reading list as markdown" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Michael Crowley" />
    <meta property="og:description" content="Computer Science student at Trinity College Dublin and CTO of Lockup. Builder of LLM tooling, full-stack web, and hardware prototypes." />
    <meta property="og:url" content={`https://michaelcrowley.dev${Astro.url.pathname}`} />
    <meta property="og:locale" content="en_IE" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="@notmcrowley" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Michael Crowley",
      "url": "https://michaelcrowley.dev/",
      "email": "michaelcrowley931@gmail.com",
      "jobTitle": "Co-founder & CTO, Lockup",
      "alumniOf": { "@type": "CollegeOrUniversity", "name": "Trinity College Dublin" },
      "worksFor": { "@type": "Organization", "name": "Lockup", "url": "https://lockup-app.com" },
      "knowsAbout": ["Large language models", "Full-stack web development", "React", "TypeScript", "Python", "AWS", "Firebase", "Snap Lens Studio"],
      "sameAs": ["https://github.com/mcrowley19", "https://x.com/notmcrowley"]
    })} />

<script defer src="https://cloud.umami.is/script.js" data-website-id="942b68b1-341a-4959-a941-569fa2f61d76"></script>
    <ClientRouter />
  </head>
  <body>
    <Nav />
    <slot />

    <footer class="page-footer" aria-label="Page performance telemetry">
      <div class="page-footer__rule" aria-hidden="true"></div>
      <div class="page-footer__heading">Telemetry · this page</div>
      <div class="page-footer__panel">
        <div class="page-footer__metric">
          <span class="page-footer__label">TTFB</span>
          <span class="page-footer__value"><span id="m-ttfb">—</span><span class="page-footer__unit">ms</span></span>
        </div>
        <div class="page-footer__metric">
          <span class="page-footer__label">DOM Ready</span>
          <span class="page-footer__value"><span id="m-dom">—</span><span class="page-footer__unit">ms</span></span>
        </div>
        <div class="page-footer__metric">
          <span class="page-footer__label">First Paint</span>
          <span class="page-footer__value"><span id="m-fcp">—</span><span class="page-footer__unit">ms</span></span>
        </div>
        <div class="page-footer__metric">
          <span class="page-footer__label">Largest Paint</span>
          <span class="page-footer__value"><span id="m-lcp">—</span><span class="page-footer__unit">ms</span></span>
        </div>
        <div class="page-footer__metric">
          <span class="page-footer__label">Transfer</span>
          <span class="page-footer__value"><span id="m-bytes">—</span><span class="page-footer__unit">kb</span></span>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var data = { ttfb: null, dom: null, fcp: null, lcp: null, bytes: null };

        function format(v, dp) {
          if (v == null) return '—';
          if (v < 10) return v.toFixed(dp == null ? 2 : dp);
          if (v < 100) return v.toFixed(1);
          return String(Math.round(v));
        }

        function render() {
          var elTtfb = document.getElementById('m-ttfb');
          var elDom = document.getElementById('m-dom');
          var elFcp = document.getElementById('m-fcp');
          var elLcp = document.getElementById('m-lcp');
          var elBytes = document.getElementById('m-bytes');
          if (elTtfb) elTtfb.textContent = format(data.ttfb);
          if (elDom) elDom.textContent = format(data.dom);
          if (elFcp) elFcp.textContent = format(data.fcp);
          if (elLcp) elLcp.textContent = format(data.lcp);
          if (elBytes) elBytes.textContent = data.bytes == null ? '—' : format(data.bytes, 1);
        }

        function readNav() {
          var nav = performance.getEntriesByType('navigation')[0];
          if (!nav) return;
          data.ttfb = Math.max(0, nav.responseStart - nav.fetchStart);
          data.dom = Math.max(0, nav.domContentLoadedEventEnd - nav.fetchStart);
          if (nav.encodedBodySize != null) data.bytes = nav.encodedBodySize / 1024;
          render();
        }

        if (document.readyState === 'complete' || document.readyState === 'interactive') {
          requestAnimationFrame(readNav);
        } else {
          window.addEventListener('DOMContentLoaded', readNav);
        }

        if (window.PerformanceObserver) {
          try {
            new PerformanceObserver(function (list) {
              list.getEntries().forEach(function (e) {
                if (e.name === 'first-contentful-paint') {
                  data.fcp = e.startTime;
                  render();
                }
              });
            }).observe({ type: 'paint', buffered: true });
          } catch (e) {}

          try {
            new PerformanceObserver(function (list) {
              var entries = list.getEntries();
              if (entries.length) {
                data.lcp = entries[entries.length - 1].startTime;
                render();
              }
            }).observe({ type: 'largest-contentful-paint', buffered: true });
          } catch (e) {}
        }
      })();
    </script>

    <!-- Speculation Rules: prerender pages on hover for instant navigation -->
    <script type="speculationrules" set:html={JSON.stringify({
      prerender: [{ where: { href_matches: "/*" }, eagerness: "eager" }]
    })} />
  </body>
</html>
