---
import Nav from '../components/Nav.astro'
import '../styles/global.css'
import frauncesNormalUrl from '@fontsource-variable/fraunces/files/fraunces-latin-wght-normal.woff2?url'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Michael Crowley — CS at Trinity College Dublin, CTO of Lockup',
  description = 'Computer Science student at Trinity College Dublin and CTO of Lockup, a phone-management app for schools. Builder of LLM tooling, full-stack web, and hardware prototypes.',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preload" as="font" type="font/woff2" href={frauncesNormalUrl} crossorigin />
    <slot name="head-preload" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Michael Crowley" />
    <link rel="canonical" href={`https://michaelcrowley.dev${Astro.url.pathname}`} />
    <link rel="alternate" type="text/markdown" href="/llms.txt" title="LLM-friendly site summary" />
    <link rel="alternate" type="text/markdown" href="/llms-full.txt" title="Full bio, projects, and reading list as markdown" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Michael Crowley" />
    <meta property="og:description" content="Computer Science student at Trinity College Dublin and CTO of Lockup. Builder of LLM tooling, full-stack web, and hardware prototypes." />
    <meta property="og:url" content={`https://michaelcrowley.dev${Astro.url.pathname}`} />
    <meta property="og:locale" content="en_IE" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="@notmcrowley" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Michael Crowley",
      "url": "https://michaelcrowley.dev/",
      "email": "michaelcrowley931@gmail.com",
      "jobTitle": "Co-founder & CTO, Lockup",
      "alumniOf": { "@type": "CollegeOrUniversity", "name": "Trinity College Dublin" },
      "worksFor": { "@type": "Organization", "name": "Lockup", "url": "https://lockup-app.com" },
      "knowsAbout": ["Large language models", "Full-stack web development", "React", "TypeScript", "Python", "AWS", "Firebase", "Snap Lens Studio"],
      "sameAs": ["https://github.com/mcrowley19", "https://x.com/notmcrowley"]
    })} />
  </head>
  <body>
    <div class="page-render-time" aria-label="Page load time">
      <span>Rendered in <span id="page-load-time">…</span><span class="page-render-time__unit">s</span></span>
    </div>
    <Nav />
    <slot />
    <footer class="site-footer">Made in Astro for speed</footer>

    <script is:inline>
      (function () {
        function format(ms) {
          if (ms == null || ms < 0) return '—';
          if (ms < 0.5) return '<0.001';
          var s = ms / 1000;
          if (s < 10) return s.toFixed(3);
          if (s < 100) return s.toFixed(2);
          return s.toFixed(1);
        }

        var el = document.getElementById('page-load-time');

        new PerformanceObserver(function (list) {
          var entry = list.getEntries().at(-1);
          if (el) el.textContent = format(entry.startTime);
        }).observe({ type: 'largest-contentful-paint', buffered: true });
      })();
    </script>

    <!-- Speculation Rules: prerender on hover for instant navigation -->
    <script type="speculationrules" set:html={JSON.stringify({
      prerender: [{ where: { href_matches: "/*" }, eagerness: "moderate" }]
    })} />

    <!-- Defer analytics until after the page is fully loaded -->
    <script is:inline>
      window.addEventListener('load', function () {
        setTimeout(function () {
          var s = document.createElement('script');
          s.defer = true;
          s.src = 'https://cloud.umami.is/script.js';
          s.setAttribute('data-website-id', '942b68b1-341a-4959-a941-569fa2f61d76');
          document.head.appendChild(s);
        }, 0);
      });
    </script>
  </body>
</html>
