---
import { ClientRouter } from 'astro:transitions'
import Nav from '../components/Nav.astro'
import '../styles/global.css'
import frauncesNormalUrl from '@fontsource-variable/fraunces/files/fraunces-latin-wght-normal.woff2?url'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Michael Crowley — CS at Trinity College Dublin, CTO of Lockup',
  description = 'Computer Science student at Trinity College Dublin and CTO of Lockup, a phone-management app for schools. Builder of LLM tooling, full-stack web, and hardware prototypes.',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preload" as="font" type="font/woff2" href={frauncesNormalUrl} crossorigin />
    <slot name="head-preload" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Michael Crowley" />
    <link rel="canonical" href={`https://michaelcrowley.dev${Astro.url.pathname}`} />
    <link rel="alternate" type="text/markdown" href="/llms.txt" title="LLM-friendly site summary" />
    <link rel="alternate" type="text/markdown" href="/llms-full.txt" title="Full bio, projects, and reading list as markdown" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Michael Crowley" />
    <meta property="og:description" content="Computer Science student at Trinity College Dublin and CTO of Lockup. Builder of LLM tooling, full-stack web, and hardware prototypes." />
    <meta property="og:url" content={`https://michaelcrowley.dev${Astro.url.pathname}`} />
    <meta property="og:locale" content="en_IE" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="@notmcrowley" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Michael Crowley",
      "url": "https://michaelcrowley.dev/",
      "email": "michaelcrowley931@gmail.com",
      "jobTitle": "Co-founder & CTO, Lockup",
      "alumniOf": { "@type": "CollegeOrUniversity", "name": "Trinity College Dublin" },
      "worksFor": { "@type": "Organization", "name": "Lockup", "url": "https://lockup-app.com" },
      "knowsAbout": ["Large language models", "Full-stack web development", "React", "TypeScript", "Python", "AWS", "Firebase", "Snap Lens Studio"],
      "sameAs": ["https://github.com/mcrowley19", "https://x.com/notmcrowley"]
    })} />

<script defer src="https://cloud.umami.is/script.js" data-website-id="942b68b1-341a-4959-a941-569fa2f61d76"></script>
    <ClientRouter />
  </head>
  <body>
    <Nav />
    <slot />

    <footer class="page-footer" aria-label="Page load time">
      <span class="page-footer__rule" aria-hidden="true"></span>
      <span class="page-footer__label">Rendered in</span>
      <span class="page-footer__value"><span id="page-load-time">…</span><span class="page-footer__unit">s</span></span>
    </footer>

    <script is:inline>
      (function () {
        var navStart = null;

        function format(ms) {
          if (ms == null || ms < 0) return '—';
          // Browsers clamp performance timings to ~0.1ms (Spectre
          // mitigation), so anything reading 0 is below that floor.
          // We render in seconds; <0.001s = under one millisecond.
          if (ms < 0.5) return '<0.001';
          var s = ms / 1000;
          if (s < 10) return s.toFixed(3);
          if (s < 100) return s.toFixed(2);
          return s.toFixed(1);
        }

        function show(ms) {
          var el = document.getElementById('page-load-time');
          if (el) el.textContent = format(ms);
        }

        function measureInitial() {
          var nav = performance.getEntriesByType('navigation')[0];
          if (!nav) return;
          // domContentLoadedEventEnd is only populated *after* every DCL
          // handler has finished, so reading it inside one returns 0. The
          // load event fires later, by which point it's set; if even that
          // isn't enough, fall back to domInteractive then responseEnd.
          var ms = nav.domContentLoadedEventEnd - nav.fetchStart;
          if (ms <= 0) ms = nav.domInteractive - nav.fetchStart;
          if (ms <= 0) ms = nav.responseEnd - nav.fetchStart;
          show(Math.max(0, ms));
        }

        if (document.readyState === 'complete') {
          measureInitial();
        } else {
          window.addEventListener('load', measureInitial);
        }

        document.addEventListener('astro:before-preparation', function () {
          navStart = performance.now();
        });
        document.addEventListener('astro:page-load', function () {
          if (navStart === null) return;
          show(performance.now() - navStart);
          navStart = null;
        });
      })();
    </script>

    <!-- Speculation Rules: prerender pages on hover for instant navigation -->
    <script type="speculationrules" set:html={JSON.stringify({
      prerender: [{ where: { href_matches: "/*" }, eagerness: "eager" }]
    })} />
  </body>
</html>
