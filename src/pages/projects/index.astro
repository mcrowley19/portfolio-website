---
import BaseLayout from '../../layouts/BaseLayout.astro'
import lockupImg from '../../assets/projects/lockup.webp'
import alpineValleyImg from '../../assets/projects/alpine-valley.avif'
import sol450Img from '../../assets/projects/sol-450.webp'
import shoelaceImg from '../../assets/projects/shoelace(1).webp'
import metricareImg from '../../assets/projects/metricare.webp'
import kangratImg from '../../assets/projects/kangrat.webp'
import microgradJavaImg from '../../assets/projects/micrograd-java.webp'
import snapswingImg from '../../assets/projects/snapswing.webp'
import linearOpsImg from '../../assets/projects/linear-ops.webp'
import learnquotesImg from '../../assets/projects/learnquotes.webp'
import tempHumidityImg from '../../assets/projects/temp&h.webp'

type Row = {
  name: string
  date: string
  tech: string
  description: string
  image?: string
  imageFilter?: string
  imageObjectFit?: 'cover' | 'contain'
  imageObjectPosition?: string
  link?: string
}

const rows: Row[] = [
  {
    name: 'Lockup',
    date: 'Apr 2026 – Present',
    tech: 'React Native, AWS',
    link: 'https://lockup-app.com',
    description:
      'Software-Driven Focus for the Modern Classroom. Lockup is an app I co-founded to give teachers the ability to monitor and restrict student phone usage during class. I am currently working as the CTO and we are in talks with multiple schools for paid pilots over the next school year.',
    image: lockupImg.src,
  },
  {
    name: 'Alpine Valley',
    date: 'Jun 2026',
    tech: 'React',
    link: 'https://alpine-valley.com',
    description:
      'Led the website redesign for Alpine Valley, a startup accelerator I joined as part of Cohort Alpha.',
    image: alpineValleyImg.src,
  },
  {
    name: 'Sol-450',
    date: 'Mar 2026',
    tech: 'React, Three.js, Python, AWS',
    description:
      'A 3D simulation of a greenhouse on Mars made as an entry to Start Hack 2026 in 36 hours. Food production managed using 6 AI agents to ensure a stable food supply.',
    image: sol450Img.src,
    imageFilter: 'saturate(1.4) brightness(1.05) contrast(0.95)',
    link: 'https://github.com/mcrowley19/mars-food-simulation',
  },
  {
    name: 'Shoelace',
    date: 'Mar 2026',
    tech: 'React, Python, FastAPI, Gemini API, Google Cloud',
    description:
      'An accessibility app that uses the Gemini Live API to guide children and those with disabilities through day-to-day tasks.',
    image: shoelaceImg.src,
    imageFilter: 'contrast(1.5) saturate(1.4) brightness(1.0) hue-rotate(10deg)',
    link: 'https://github.com/mcrowley19/shoelace',
  },
  {
    name: 'Metricare',
    date: 'Feb 2026',
    tech: 'React, TypeScript, Python, FastAPI, Gemini API, Vercel',
    description:
      'An AI medical dashboard designed to summarise patient data for clinicians and identify possible contraindications for drugs.',
    image: metricareImg.src,
    imageFilter: 'saturate(0.75) contrast(0.85) brightness(1.05) sepia(0.2)',
    link: 'https://metricare.vercel.app/',
  },
  {
    name: 'Kangrat',
    date: 'Feb 2026',
    tech: 'React, TypeScript, Firebase, Algolia',
    description:
      'A professional networking platform with profiles, messaging, job discovery, and a gamified XP levelling system. Made solely by me in less than one week.',
    image: kangratImg.src,
    imageFilter: 'sepia(0.4) contrast(0.9) brightness(1.05)',
    link: 'https://www.kangrat.com/discover',
  },
  {
    name: 'micrograd-java',
    date: 'Jan 2026',
    tech: 'Java, Maven',
    description:
      "A Java remake of Andrej Karpathy's micrograd engine I made to gain a better understanding of backpropagation.",
    image: microgradJavaImg.src,
    imageFilter: 'sepia(0.35) contrast(0.85) brightness(1.08)',
    link: 'https://github.com/mcrowley19/micrograd-java',
  },
  {
    name: 'Snap and Swing',
    date: 'Dec 2025',
    tech: 'TypeScript, Snap Lens Studio',
    description:
      'A swinging Snapchat AR game. Winner of 2nd place in the 2D category at the Snap Lensathon. Played over 21 million times.',
    image: snapswingImg.src,
    imageFilter: 'saturate(0.7) contrast(0.85) brightness(1.05) sepia(0.2)',
    link: 'https://devpost.com/software/snap-and-swing',
  },
  {
    name: 'LinearOps',
    date: 'Nov 2025',
    tech: 'Python',
    description:
      'A Python library for linear algebra operations that supports matrix and vector computations.',
    image: linearOpsImg.src,
    imageFilter: 'saturate(0.6) contrast(0.8) brightness(1.1) sepia(0.15)',
    link: 'https://github.com/mcrowley19/LinearOps',
  },
  {
    name: 'learnquotes.com',
    date: 'Jul 2025',
    tech: 'React, TypeScript, AWS',
    description:
      'A website for Leaving Cert students to revise Shakespeare quotes.',
    image: learnquotesImg.src,
    imageFilter: 'saturate(0.55) contrast(0.8) brightness(1.1) sepia(0.2)',
    link: 'https://learnquotes.com',
    imageObjectPosition: 'top left',
  },
  {
    name: 'Temperature and humidity tracker',
    date: 'March 2025',
    tech: 'Cloudflare, Flask, DHT22 Sensors, Raspberry Pi',
    description:
      'A website built for tracking temperature and humidity levels across the house.',
    image: tempHumidityImg.src,
    imageFilter: 'saturate(0.6) contrast(0.85) brightness(1.05) sepia(0.25)',
  },
]

const RULE = '1px solid rgba(26, 26, 26, 0.12)'
---

<BaseLayout title="Projects — Michael Crowley">
  <main
    class="w-full pb-24"
    style="padding-left: 12vw; padding-right: 1.5rem; padding-top: 8vh"
  >
    <div style="max-width: 580px">
      <h1
        class="font-display text-ink-primary"
        style="font-size: 1.5rem; font-weight: 300; line-height: 1.2"
      >
        Projects
      </h1>

      <ol
        style={`list-style: none; margin: 0; padding: 0; margin-top: 3rem; border-top: ${RULE}`}
      >
        {rows.map((p) => (
          <li
            style={`padding-top: 1.8rem; padding-bottom: 1.8rem; border-bottom: ${RULE}`}
          >
            <div
              class="project-row"
              style="display: flex; align-items: flex-start; gap: 1.25rem"
            >
              {p.image ? (
                <img
                  src={p.image}
                  alt=""
                  aria-hidden="true"
                  style={`width: 140px; height: 90px; object-fit: ${p.imageObjectFit ?? 'cover'}; object-position: ${p.imageObjectPosition ?? 'center'}; filter: ${p.imageFilter ?? 'grayscale(1)'}; flex: 0 0 140px; display: block`}
                />
              ) : (
                <div
                  aria-hidden="true"
                  style="width: 140px; height: 90px; background-color: #8A8682; flex: 0 0 140px"
                />
              )}
              <div style="flex: 1 1 auto; min-width: 0">
                <div style="display: flex; align-items: baseline; gap: 1rem; width: 100%">
                  <span
                    class="font-display text-ink-primary"
                    style="font-size: 1.05rem; font-weight: 400; line-height: 1.3"
                  >
                    {p.name}
                  </span>
                  <span
                    class="font-mono"
                    style="font-size: 0.72rem; color: rgba(26, 26, 26, 0.55); margin-left: auto; white-space: nowrap"
                  >
                    {p.date}
                  </span>
                </div>
                <p
                  class="font-display"
                  style="font-size: 0.88rem; line-height: 1.5; color: rgba(26, 26, 26, 0.7); margin: 0.6rem 0 0.55rem 0"
                >
                  {p.description}
                </p>
                <div
                  class="font-mono"
                  style="font-size: 0.7rem; color: rgba(26, 26, 26, 0.5); letter-spacing: 0.02em"
                >
                  {p.tech}
                </div>
                {p.link && (
                  <a
                    href={p.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-mono"
                    style="display: inline-block; margin-top: 0.45rem; font-size: 0.7rem; color: rgba(26, 26, 26, 0.5); text-decoration: underline; text-decoration-color: rgba(26, 26, 26, 0.25); text-underline-offset: 3px; letter-spacing: 0.02em"
                  >
                    {p.link.replace(/^https?:\/\//, '')}
                  </a>
                )}
              </div>
            </div>
          </li>
        ))}
      </ol>
    </div>

    <style is:global>
      @media (max-width: 640px) {
        .project-row {
          flex-direction: column;
        }
        .project-row > div:last-child {
          width: 100%;
        }
      }
    </style>
  </main>
</BaseLayout>
