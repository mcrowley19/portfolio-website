---
import BaseLayout from '../../layouts/BaseLayout.astro'
import lockupImg from '../../assets/projects/lockup.avif'
import alpineValleyImg from '../../assets/projects/alpine-valley.avif'
import sol450Img from '../../assets/projects/sol-450.avif'
import shoelaceImg from '../../assets/projects/shoelace_1_.avif'
import metricareImg from '../../assets/projects/metricare.avif'
import kangratImg from '../../assets/projects/kangrat.avif'
import microgradJavaImg from '../../assets/projects/micrograd-java.avif'
import snapswingImg from '../../assets/projects/snapswing.avif'
import linearOpsImg from '../../assets/projects/linear-ops.avif'
import learnquotesImg from '../../assets/projects/learnquotes.avif'
import tempHumidityImg from '../../assets/projects/temp-h.avif'

type Row = {
  name: string
  date: string
  tech: string
  description: string
  image?: string
  imageFilter?: string
  imageObjectFit?: 'cover' | 'contain'
  imageObjectPosition?: string
  link?: string
}

const rows: Row[] = [
  {
    name: 'Lockup',
    date: 'Apr 2026 – Present',
    tech: 'React Native, AWS',
    link: 'https://lockup-app.com',
    description:
      'Software-Driven Focus for the Modern Classroom. Lockup is an app I co-founded to give teachers the ability to monitor and restrict student phone usage during class. I am currently working as the CTO and we are in talks with multiple schools for paid pilots over the next school year.',
    image: lockupImg.src,
  },
  {
    name: 'Alpine Valley',
    date: 'Jun 2026',
    tech: 'React',
    link: 'https://alpine-valley.com',
    description:
      'Led the website redesign for Alpine Valley, a startup accelerator I joined as part of Cohort Alpha.',
    image: alpineValleyImg.src,
  },
  {
    name: 'Sol-450',
    date: 'Mar 2026',
    tech: 'React, Three.js, Python, AWS',
    description:
      'A 3D simulation of a greenhouse on Mars made as an entry to Start Hack 2026 in 36 hours. Food production managed using 6 AI agents to ensure a stable food supply.',
    image: sol450Img.src,
    imageFilter: 'saturate(1.4) brightness(1.05) contrast(0.95)',
    link: 'https://github.com/mcrowley19/mars-food-simulation',
  },
  {
    name: 'Shoelace',
    date: 'Mar 2026',
    tech: 'React, Python, FastAPI, Gemini API, Google Cloud',
    description:
      'An accessibility app that uses the Gemini Live API to guide children and those with disabilities through day-to-day tasks.',
    image: shoelaceImg.src,
    imageFilter: 'contrast(1.5) saturate(1.4) brightness(1.0) hue-rotate(10deg)',
    link: 'https://github.com/mcrowley19/shoelace',
  },
  {
    name: 'Metricare',
    date: 'Feb 2026',
    tech: 'React, TypeScript, Python, FastAPI, Gemini API, Vercel',
    description:
      'An AI medical dashboard designed to summarise patient data for clinicians and identify possible contraindications for drugs.',
    image: metricareImg.src,
    imageFilter: 'saturate(0.75) contrast(0.85) brightness(1.05) sepia(0.2)',
    link: 'https://metricare.vercel.app/',
  },
  {
    name: 'Kangrat',
    date: 'Feb 2026',
    tech: 'React, TypeScript, Firebase, Algolia',
    description:
      'A professional networking platform with profiles, messaging, job discovery, and a gamified XP levelling system. Made solely by me in less than one week.',
    image: kangratImg.src,
    imageFilter: 'sepia(0.4) contrast(0.9) brightness(1.05)',
    link: 'https://www.kangrat.com/discover',
  },
  {
    name: 'micrograd-java',
    date: 'Jan 2026',
    tech: 'Java, Maven',
    description:
      "A Java remake of Andrej Karpathy's micrograd engine I made to gain a better understanding of backpropagation.",
    image: microgradJavaImg.src,
    imageFilter: 'sepia(0.35) contrast(0.85) brightness(1.08)',
    link: 'https://github.com/mcrowley19/micrograd-java',
  },
  {
    name: 'Snap and Swing',
    date: 'Dec 2025',
    tech: 'TypeScript, Snap Lens Studio',
    description:
      'A swinging Snapchat AR game. Winner of 2nd place in the 2D category at the Snap Lensathon. Played over 21 million times.',
    image: snapswingImg.src,
    imageFilter: 'saturate(0.7) contrast(0.85) brightness(1.05) sepia(0.2)',
    link: 'https://devpost.com/software/snap-and-swing',
  },
  {
    name: 'LinearOps',
    date: 'Nov 2025',
    tech: 'Python',
    description:
      'A Python library for linear algebra operations that supports matrix and vector computations.',
    image: linearOpsImg.src,
    imageFilter: 'saturate(0.6) contrast(0.8) brightness(1.1) sepia(0.15)',
    link: 'https://github.com/mcrowley19/LinearOps',
  },
  {
    name: 'learnquotes.com',
    date: 'Jul 2025',
    tech: 'React, TypeScript, AWS',
    description:
      'A website for Leaving Cert students to revise Shakespeare quotes.',
    image: learnquotesImg.src,
    imageFilter: 'saturate(0.55) contrast(0.8) brightness(1.1) sepia(0.2)',
    link: 'https://learnquotes.com',
    imageObjectPosition: 'top left',
  },
  {
    name: 'Temperature and humidity tracker',
    date: 'March 2025',
    tech: 'Cloudflare, Flask, DHT22 Sensors, Raspberry Pi',
    description:
      'A website built for tracking temperature and humidity levels across the house.',
    image: tempHumidityImg.src,
    imageFilter: 'saturate(0.6) contrast(0.85) brightness(1.05) sepia(0.25)',
  },
]

const RULE = '1px solid rgba(26, 26, 26, 0.12)'
---

<BaseLayout title="Projects — Michael Crowley">
  <main class="projects-main w-full pb-24">
    <div style="max-width: 580px">
      <h1
        class="font-display text-ink-primary"
        style="font-size: 1.5rem; font-weight: 300; line-height: 1.2"
      >
        Projects
      </h1>

      <ol
        style={`list-style: none; margin: 0; padding: 0; margin-top: 3rem; border-top: ${RULE}`}
      >
        {rows.map((p, i) => (
          <li
            style={`padding-top: 1.8rem; padding-bottom: 1.8rem; border-bottom: ${RULE}`}
          >
            <div class="project-row">
              {p.image ? (
                <img
                  class="project-thumb"
                  src={p.image}
                  alt=""
                  aria-hidden="true"
                  width="140"
                  height="90"
                  loading={i > 1 ? 'lazy' : 'eager'}
                  decoding={i > 1 ? 'async' : undefined}
                  fetchpriority={i === 0 ? 'high' : undefined}
                  style={`object-fit: ${p.imageObjectFit ?? 'cover'}; object-position: ${p.imageObjectPosition ?? 'center'}; filter: ${p.imageFilter ?? 'grayscale(1)'}`}
                />
              ) : (
                <div class="project-thumb" aria-hidden="true" style="background-color: #8A8682" />
              )}
              <span class="project-name font-display text-ink-primary">{p.name}</span>
              <span class="project-date font-mono">{p.date}</span>
              <p class="project-desc font-display">{p.description}</p>
              <div class="project-tech font-mono">{p.tech}</div>
              {p.link && (
                <a
                  href={p.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="project-link font-mono"
                >
                  {p.link.replace(/^https?:\/\//, '')}
                </a>
              )}
            </div>
          </li>
        ))}
      </ol>
    </div>

    <style is:global>
      .projects-main {
        padding-top: 8vh;
        padding-left: 12vw;
        padding-right: 1.5rem;
      }

      .project-row {
        display: grid;
        grid-template-columns: 140px minmax(0, 1fr) auto;
        grid-template-areas:
          'thumb name date'
          'thumb desc desc'
          'thumb tech tech'
          'thumb link link';
        /* The 1fr tail row absorbs leftover height when the thumb is taller
           than the text, instead of opening gaps between text rows. */
        grid-template-rows: auto auto auto 1fr;
        column-gap: 1.25rem;
      }

      .project-thumb {
        grid-area: thumb;
        display: block;
        width: 140px;
        height: 90px;
        align-self: start;
      }

      .project-name {
        grid-area: name;
        align-self: baseline;
        font-size: 1.05rem;
        font-weight: 400;
        line-height: 1.3;
      }

      .project-date {
        grid-area: date;
        align-self: baseline;
        justify-self: end;
        font-size: 0.72rem;
        color: rgba(26, 26, 26, 0.55);
        white-space: nowrap;
      }

      .project-desc {
        grid-area: desc;
        font-size: 0.88rem;
        line-height: 1.5;
        color: rgba(26, 26, 26, 0.7);
        margin: 0.6rem 0 0.55rem 0;
      }

      .project-tech {
        grid-area: tech;
        align-self: start;
        font-size: 0.7rem;
        color: rgba(26, 26, 26, 0.5);
        letter-spacing: 0.02em;
      }

      .project-link {
        grid-area: link;
        justify-self: start;
        align-self: start;
        margin-top: 0.45rem;
        font-size: 0.7rem;
        color: rgba(26, 26, 26, 0.5);
        text-decoration: underline;
        text-decoration-color: rgba(26, 26, 26, 0.25);
        text-underline-offset: 3px;
        letter-spacing: 0.02em;
      }

      /* Mobile: catalog entry — thumb and metadata form a spec block,
         description runs below at full measure. */
      @media (max-width: 640px) {
        .projects-main {
          padding-left: 1.5rem;
        }

        .project-row {
          grid-template-columns: 104px minmax(0, 1fr);
          grid-template-areas:
            'thumb name'
            'thumb date'
            'thumb tech'
            'desc desc'
            'link link';
          grid-template-rows: auto auto 1fr auto auto;
          column-gap: 1.1rem;
        }

        .project-thumb {
          width: 104px;
          height: 68px;
        }

        .project-name {
          font-size: 1rem;
        }

        .project-date {
          justify-self: start;
          margin-top: 0.35rem;
        }

        .project-tech {
          margin-top: 0.55rem;
        }

        .project-desc {
          margin: 1rem 0 0 0;
        }

        .project-link {
          margin-top: 0.5rem;
        }
      }
    </style>
  </main>
</BaseLayout>
