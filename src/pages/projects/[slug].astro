---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { projects } from '../../data/projects'

export function getStaticPaths() {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }))
}

const { project } = Astro.props
---

<BaseLayout title={`${project.name} — Michael Crowley`}>
  <main class="mx-auto min-h-screen w-full max-w-[80rem] px-6 pb-32 sm:px-10 md:px-16">
    <div class="grid grid-cols-12 gap-x-6">
      <div class="col-span-12 md:col-span-10 md:col-start-2 pt-32 md:pt-48">
        <a href="/" class="font-mono text-numeral text-ink-tertiary transition-colors hover:text-accent-vermilion">
          ← Index
        </a>
        <article class="mt-12 border-t border-rule-line pt-12">
          <header class="mb-8 flex items-baseline gap-6">
            <span class="font-mono text-numeral text-ink-tertiary">{project.numeral}</span>
            <h1 class="font-display text-display-m">{project.name}</h1>
          </header>
          <div class="max-w-[65ch] space-y-6 font-display text-body-m text-ink-primary">
            {project.paragraphs.map((p) => <p>{p}</p>)}
          </div>
          <dl class="mt-10 grid grid-cols-1 gap-x-12 gap-y-3 font-mono text-numeral text-ink-secondary sm:grid-cols-[max-content_1fr]">
            <dt class="uppercase text-ink-tertiary">Role</dt>
            <dd>{project.role}</dd>
            <dt class="uppercase text-ink-tertiary">Timeframe</dt>
            <dd>{project.timeframe}</dd>
            <dt class="uppercase text-ink-tertiary">Status</dt>
            <dd>{project.status}</dd>
          </dl>
          <p class="mt-8 font-mono text-numeral">
            <a href={project.link.href} target="_blank" rel="noreferrer" class="text-ink-primary underline decoration-ink-tertiary underline-offset-4 transition-colors hover:text-accent-vermilion hover:decoration-accent-vermilion">
              {project.link.label}
            </a>
          </p>
        </article>
      </div>
    </div>
  </main>
</BaseLayout>
