---
const { pathname } = Astro.url

const links = [
  { to: '/', label: 'Home' },
  { to: '/projects', label: 'Projects' },
  { to: '/reading', label: 'Reading' },
]

function isActive(to: string) {
  if (to === '/') return pathname === '/'
  return pathname.startsWith(to)
}
---

<nav class="mx-auto w-full max-w-[80rem] px-6 sm:px-10 md:px-16 pt-10 flex gap-8 justify-end">
  {links.map(({ to, label }) => (
    <a
      href={to}
      class:list={[
        'font-body font-light text-[0.9rem] lowercase tracking-normal transition-colors',
        isActive(to) ? 'text-accent-vermilion' : 'text-ink-primary/70 hover:text-ink-primary',
      ]}
    >
      {label}
    </a>
  ))}
</nav>
