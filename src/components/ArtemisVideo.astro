---
import artemisVideo from '../assets/artemis.mp4'

interface Props {
  maxWidth?: number | string
}

const { maxWidth = '100%' } = Astro.props
const maxWidthStyle = typeof maxWidth === 'number' ? `${maxWidth}px` : maxWidth
---

<div
  aria-hidden="true"
  class="artemis-wrap pointer-events-none relative overflow-hidden"
  style={`width: 100%; max-width: ${maxWidthStyle};`}
>
  <video
    class="artemis-video block w-full"
    src={artemisVideo}
    muted
    playsinline
    loop={false}
    preload="none"
  ></video>
</div>

<script is:inline>
  (function () {
    if (window.__artemisInit) return;
    window.__artemisInit = true;

    var STORAGE_KEY = 'artemis-start-ts';

    function startOrResume(video) {
      var stored = sessionStorage.getItem(STORAGE_KEY);
      if (!stored) {
        sessionStorage.setItem(STORAGE_KEY, Date.now().toString());
        video.play().catch(function () {});
        return;
      }
      function seek() {
        var elapsed = (Date.now() - Number(stored)) / 1000;
        var dur = video.duration;
        if (isFinite(dur) && elapsed >= dur) {
          try { video.currentTime = dur; } catch (e) {}
        } else {
          try { video.currentTime = elapsed; } catch (e) {}
          video.play().catch(function () {});
        }
      }
      if (video.readyState >= 1) {
        seek();
      } else {
        video.addEventListener('loadedmetadata', seek, { once: true });
        video.load();
      }
    }

    function setupVideos() {
      var videos = document.querySelectorAll('.artemis-video');
      for (var i = 0; i < videos.length; i++) {
        (function (video) {
          new IntersectionObserver(
            function (entries, obs) {
              for (var j = 0; j < entries.length; j++) {
                if (entries[j].isIntersecting) {
                  obs.disconnect();
                  startOrResume(entries[j].target);
                }
              }
            },
            { threshold: 0.5 },
          ).observe(video);
        })(videos[i]);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupVideos);
    } else {
      setupVideos();
    }
  })();
</script>
